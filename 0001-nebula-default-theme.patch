From 5b71fbc26265c291207ffab872a54f0456691298 Mon Sep 17 00:00:00 2001
From: Slick <slick@slicksync.local>
Date: Sun, 12 Jul 2026 20:48:12 +0000
Subject: [PATCH] feat: Nebula is now the default theme

Changed all three references (ThemeContext default value, useState
initial value, and the localStorage-fallback value) from slick to
nebula, plus moved the CSS :root selector from Slick's block to
Nebula's so there's no flash-of-wrong-theme before JS hydrates.
Existing users with a saved theme preference (localStorage) are
unaffected.

Bump to 1.9.37, changelog entry added.
---
 client/app/globals.css       |  6 +++---
 client/lib/theme.tsx         |  6 +++---
 client/public/changelog.json | 10 ++++++++++
 3 files changed, 16 insertions(+), 6 deletions(-)

diff --git a/client/app/globals.css b/client/app/globals.css
index 0a574ee..90840ca 100644
--- a/client/app/globals.css
+++ b/client/app/globals.css
@@ -7,8 +7,7 @@
 
 /* ===== THEME DEFINITIONS ===== */
 
-/* Slick Theme (default) - Soft violet + muted teal */
-:root,
+/* Slick Theme - Soft violet + muted teal */
 html.slick {
   /* Background spectrum */
   --color-bg: #050308;
@@ -98,7 +97,8 @@ html.velvet {
   --radius-xl: 20px;
 }
 
-/* Nebula Theme - Deep blue-black (Midnight structure) with violet-to-cyan accents */
+/* Nebula Theme (default) - Deep blue-black (Midnight structure) with violet-to-cyan accents */
+:root,
 html.nebula {
   /* Background spectrum */
   --color-bg: #0d1117;
diff --git a/client/lib/theme.tsx b/client/lib/theme.tsx
index 478d5ad..3fa2a18 100644
--- a/client/lib/theme.tsx
+++ b/client/lib/theme.tsx
@@ -83,7 +83,7 @@ interface ThemeContextValue {
 }
 
 const defaultContextValue: ThemeContextValue = {
-  themeId: 'slick',
+  themeId: 'nebula',
   setTheme: () => {},
   hideSensitive: false,
   toggleHideSensitive: () => {},
@@ -92,7 +92,7 @@ const defaultContextValue: ThemeContextValue = {
 const ThemeContext = createContext<ThemeContextValue>(defaultContextValue);
 
 export function ThemeProvider({ children }: { children: ReactNode }) {
-  const [themeId, setThemeId] = useState<ThemeId>('slick');
+  const [themeId, setThemeId] = useState<ThemeId>('nebula');
   const [hideSensitive, setHideSensitive] = useState(false);
   const [mounted, setMounted] = useState(false);
 
@@ -100,7 +100,7 @@ export function ThemeProvider({ children }: { children: ReactNode }) {
   useEffect(() => {
     const savedTheme = localStorage.getItem('slicksync-theme') as ThemeId | null;
     const savedHideSensitive = localStorage.getItem('slicksync-hide-sensitive') === 'true';
-    const initial = savedTheme && themeIds.includes(savedTheme) ? savedTheme : 'slick';
+    const initial = savedTheme && themeIds.includes(savedTheme) ? savedTheme : 'nebula';
     setThemeId(initial);
     setHideSensitive(savedHideSensitive);
     document.documentElement.className = initial;
diff --git a/client/public/changelog.json b/client/public/changelog.json
index f6c4d85..581594c 100644
--- a/client/public/changelog.json
+++ b/client/public/changelog.json
@@ -1,4 +1,14 @@
 [
+  {
+    "version": "1.9.37",
+    "date": "2026-07-12",
+    "title": "Nebula is now the default theme",
+    "features": [
+      "Changed the default theme from Slick to Nebula, everywhere the default is referenced: the theme context's initial value, the fallback when no saved preference exists, and the CSS :root fallback (so there's no flash of the old default before the page finishes loading). Existing users with a saved theme preference are unaffected - this only changes what a fresh browser/first visit gets."
+    ],
+    "bugFixes": [],
+    "miscChores": []
+  },
   {
     "version": "1.9.35",
     "date": "2026-07-12",
-- 

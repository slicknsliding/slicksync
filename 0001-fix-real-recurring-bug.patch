From 83d6545710ece6a5051d001c3cbcae88b2bca39c Mon Sep 17 00:00:00 2001
From: Slick <slick@slicksync.local>
Date: Sat, 11 Jul 2026 20:56:37 +0000
Subject: [PATCH] fix: gate recordMovieWatch/recordEpisodeWatch on
 isActuallyWatched

The v1.9.3/v1.9.6 isActuallyWatched fixes were never the real
gatekeeper here - they only touched Discord notifications and a
legacy library-scan heuristic. processLibraryItem's actual write
path (recordMovieWatch/recordEpisodeWatch, which feeds
MovieWatchHistory/EpisodeWatchHistory and thus the Activity page) had
no watched-check at all - recordMovieWatch's only gate was
item.type === 'movie'. A pure library bookmark defaulted watchedAt to
now() and got rewritten every single poll cycle forever, which is why
cleanup never stuck.

Added the same isActuallyWatched logic directly in
metricsProcessor.js and gated both record functions on it.

Bump to 1.9.8, changelog entry added.
---
 client/public/changelog.json     | 10 ++++++++++
 package.json                     |  2 +-
 server/utils/metricsProcessor.js | 34 ++++++++++++++++++++++++++++----
 3 files changed, 41 insertions(+), 5 deletions(-)

diff --git a/client/public/changelog.json b/client/public/changelog.json
index a9e2650..3e5b97c 100644
--- a/client/public/changelog.json
+++ b/client/public/changelog.json
@@ -1,4 +1,14 @@
 [
+  {
+    "version": "1.9.8",
+    "date": "2026-07-11",
+    "title": "Fix the real cause of bookmarked-but-unwatched titles reappearing every poll cycle",
+    "bugFixes": [
+      "The isActuallyWatched() fixes in v1.9.3 and v1.9.6 were never actually the gatekeeper for this - they only affected Discord notifications and a legacy library-scan heuristic. The code path that actually writes to MovieWatchHistory/EpisodeWatchHistory (processLibraryItem -> recordMovieWatch/recordEpisodeWatch in metricsProcessor.js) had no 'was this actually watched' check at all - recordMovieWatch's only gate was item.type === 'movie'. A pure library bookmark (no video_id, no position, no state.lastWatched) sailed straight through and defaulted watchedAt to 'now', on every single poll cycle, forever - which is exactly why cleanup never stuck and the same titles kept reappearing with a fresh timestamp each time no matter how many times the DB was cleaned. Added the same isActuallyWatched gate (requires timeWatched, or progress >= 5% of runtime, or a video_id when duration is unavailable) directly in metricsProcessor.js before recordMovieWatch/recordEpisodeWatch run."
+    ],
+    "features": [],
+    "miscChores": []
+  },
   {
     "version": "1.9.7",
     "date": "2026-07-11",
diff --git a/package.json b/package.json
index beff0bc..ae06f36 100644
--- a/package.json
+++ b/package.json
@@ -1,6 +1,6 @@
 {
   "name": "slicksync",
-  "version": "1.9.7",
+  "version": "1.9.8",
   "description": "SlickSync - Stremio addon and user management system",
   "main": "server/index.js",
   "scripts": {
diff --git a/server/utils/metricsProcessor.js b/server/utils/metricsProcessor.js
index e699a10..d98ba1d 100644
--- a/server/utils/metricsProcessor.js
+++ b/server/utils/metricsProcessor.js
@@ -49,13 +49,37 @@ function extractSeasonEpisode(videoId) {
   return { season: null, episode: null }
 }
 
+/**
+ * Check if an item was actually watched vs just bookmarked/previewed.
+ * Nonzero position alone isn't reliable - Nuvio records some position for
+ * brief preview/hover autoplay, and a pure library bookmark has no position
+ * at all but would otherwise sail through with no gate whatsoever. Require
+ * either real timeWatched, or progress that's a meaningful fraction (5%,
+ * same threshold used by AIOManager) of the item's actual runtime.
+ */
+function isActuallyWatched(item) {
+  const state = item.state || {}
+  const timeWatched = Number(state.timeWatched || 0)
+  if (timeWatched > 0) return true
+
+  const progressMs = Math.max(Number(state.timeOffset || 0), Number(state.overallTimeWatched || 0))
+  if (progressMs <= 0) return false
+
+  const duration = Number(state.duration || 0)
+  if (duration > 0) {
+    return (progressMs / duration) > 0.05
+  }
+
+  return !!(state.video_id && state.video_id.trim() !== '')
+}
+
 /**
  * Record episode watch in history (for series items)
  */
 async function recordEpisodeWatch(prisma, accountId, userId, item) {
   try {
-    // Only process series items with video_id
-    if (item.type !== 'series' || !item.state?.video_id) return
+    // Only process series items with video_id and real watch progress
+    if (item.type !== 'series' || !item.state?.video_id || !isActuallyWatched(item)) return
 
     const videoId = item.state.video_id
     const showId = item._id || item.id
@@ -120,8 +144,10 @@ async function recordEpisodeWatch(prisma, accountId, userId, item) {
  */
 async function recordMovieWatch(prisma, accountId, userId, item) {
   try {
-    // Only process movie items
-    if (item.type !== 'movie') return false
+    // Only process movie items with real watch progress - a bare library
+    // bookmark (no video_id, no position) was previously sailing through
+    // here unconditionally, since the only check was item.type === 'movie'
+    if (item.type !== 'movie' || !isActuallyWatched(item)) return false
 
     const itemId = item._id || item.id
     if (!itemId) return false

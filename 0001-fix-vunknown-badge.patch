From 07eb5574c86c5d210cb8297eda6e82e159acdc96 Mon Sep 17 00:00:00 2001
From: Slick <slick@slicksync.local>
Date: Sun, 12 Jul 2026 02:50:02 +0000
Subject: [PATCH] fix: vunknown badge on imported Nuvio addons

v1.9.11 defaulted an addon's version to the string 'unknown' when
Nuvio's addon data has none. VersionBadge only skips rendering when
version is falsy, so it rendered 'v' + the literal string 'unknown'
instead of hiding the badge like it does for other addons with no
version info. Changed the fallback to null.

Bump to 1.9.12, changelog entry added.
---
 client/public/changelog.json | 10 ++++++++++
 package.json                 |  2 +-
 server/routes/users.js       |  4 ++--
 3 files changed, 13 insertions(+), 3 deletions(-)

diff --git a/client/public/changelog.json b/client/public/changelog.json
index a5bde6f..b6d3b77 100644
--- a/client/public/changelog.json
+++ b/client/public/changelog.json
@@ -1,4 +1,14 @@
 [
+  {
+    "version": "1.9.12",
+    "date": "2026-07-11",
+    "title": "Fix 'vunknown' badge on imported Nuvio addons",
+    "bugFixes": [
+      "The v1.9.11 fix defaulted an addon's version to the string 'unknown' when Nuvio's addon data didn't include one (Nuvio's addon rows have no version field at all). The frontend's VersionBadge only skips rendering when version is falsy, so it rendered the literal string 'unknown' with a 'v' prefix - showing 'vunknown' on every imported Nuvio addon. Changed the fallback to null so the badge correctly doesn't render at all when no version is known, same as it already does for other addons missing version info."
+    ],
+    "features": [],
+    "miscChores": []
+  },
   {
     "version": "1.9.11",
     "date": "2026-07-11",
diff --git a/package.json b/package.json
index e196742..c8d9355 100644
--- a/package.json
+++ b/package.json
@@ -1,6 +1,6 @@
 {
   "name": "slicksync",
-  "version": "1.9.11",
+  "version": "1.9.12",
   "description": "SlickSync - Stremio addon and user management system",
   "main": "server/index.js",
   "scripts": {
diff --git a/server/routes/users.js b/server/routes/users.js
index 134f64d..02e58dd 100644
--- a/server/routes/users.js
+++ b/server/routes/users.js
@@ -1751,13 +1751,13 @@ module.exports = ({ prisma, getAccountId, scopedWhere, INSTANCE_TYPE, decrypt, e
             id: a?.manifest?.id || a?.transportUrl || 'unknown',
             name: a?.manifest?.name || a?.transportName || 'Unknown',
             manifestUrl: a?.transportUrl || null,
-            version: a?.manifest?.version || 'unknown',
+            version: a?.manifest?.version || null,
             description: a?.manifest?.description || '',
             iconUrl: a?.manifest?.logo || null,
             manifest: {
               id: a?.manifest?.id || 'unknown',
               name: a?.manifest?.name || 'Unknown',
-              version: a?.manifest?.version || 'unknown',
+              version: a?.manifest?.version || null,
               description: a?.manifest?.description || '',
               logo: a?.manifest?.logo || null,
               types: a?.manifest?.types || ['other'],
-- 

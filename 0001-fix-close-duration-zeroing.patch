From d65961ce4e9343027050f51dbbddb036803fc0b1 Mon Sep 17 00:00:00 2001
From: Slick <slick@slicksync.local>
Date: Sun, 12 Jul 2026 21:04:33 +0000
Subject: [PATCH] fix: stored watch duration permanently zeroed on session
 close

v1.9.36 fixed the live-display duration but missed a separate code
path: closing a session computed endTime from
lastActivityByItemId (the provider's checkpoint timestamp), and if
that checkpoint never advanced during the whole session (the same
freezing behavior proven earlier), endTime came out identical to the
session's own startTime - so every closed session was permanently
stored with durationSeconds: 0, regardless of real watch time.

Confirmed directly via DB query: From, A Goofy Movie, and Obsession
all closed with endTime === startTime exactly.

Added a parallel lastPositionByItemId map (populated alongside the
existing lastActivityByItemId) and changed the close-time duration
calculation to use real position delta (lastPosition - startPosition)
when available, matching the update path's logic from v1.9.36. Falls
back to the old timestamp-based calculation only when startPosition
is unavailable (sessions created before v1.9.36).

Bump to 1.9.38, changelog entry added.
---
 client/public/changelog.json   | 10 ++++++++++
 server/utils/sessionTracker.js | 25 +++++++++++++++++++++++--
 2 files changed, 33 insertions(+), 2 deletions(-)

diff --git a/client/public/changelog.json b/client/public/changelog.json
index 9f02170..bd9b667 100644
--- a/client/public/changelog.json
+++ b/client/public/changelog.json
@@ -1,4 +1,14 @@
 [
+  {
+    "version": "1.9.38",
+    "date": "2026-07-12",
+    "title": "Fix stored watch duration being permanently zeroed on session close",
+    "bugFixes": [
+      "v1.9.36 fixed the live-display duration to use real position delta instead of wall-clock time, but the separate close-session code path (which writes the final, permanent durationSeconds when a session ends) was untouched and still computed endTime from lastActivityByItemId - the provider's checkpoint timestamp. If that checkpoint never advanced during the whole time a session was open (the same freezing behavior proven earlier tonight), endTime came out identical to the session's own startTime, so the closed session was permanently stored with durationSeconds: 0 regardless of how long it was actually active. Confirmed directly: From, A Goofy Movie, and Obsession all closed with endTime exactly equal to startTime. The close path now uses the same real-position-delta calculation as the update path when startPosition data is available (only for sessions created after v1.9.36 - older sessions' already-zeroed data isn't retroactively fixed)."
+    ],
+    "features": [],
+    "miscChores": []
+  },
   {
     "version": "1.9.36",
     "date": "2026-07-12",
diff --git a/server/utils/sessionTracker.js b/server/utils/sessionTracker.js
index 84345b0..a6382ff 100644
--- a/server/utils/sessionTracker.js
+++ b/server/utils/sessionTracker.js
@@ -310,6 +310,11 @@ async function processUserSessions(prisma, accountId, userId, library, now = new
   // Track last activity time per item from the library (lastWatched only)
   // NOTE: Do NOT use _mtime - that's modification time, not watch time
   const lastActivityByItemId = new Map()
+  // Track last known playback position per item, so a closing session's
+  // final duration can be computed the same real-progress way as an
+  // updating one (see below) instead of falling back to a checkpoint
+  // timestamp that may never have moved during the whole session.
+  const lastPositionByItemId = new Map()
 
   // Process each library item
   for (const item of library) {
@@ -337,6 +342,10 @@ async function processUserSessions(prisma, accountId, userId, library, now = new
     if (watchDate) {
       lastActivityByItemId.set(itemId, watchDate)
     }
+    const currentPositionForItem = Number(state.timeOffset ?? state.overallTimeWatched ?? NaN)
+    if (!Number.isNaN(currentPositionForItem)) {
+      lastPositionByItemId.set(itemId, currentPositionForItem)
+    }
 
     const isActive = isActivelyWatching(item, userId, nowMs)
     const videoId = item.type === 'series' ? state.video_id : null
@@ -496,8 +505,20 @@ async function processUserSessions(prisma, accountId, userId, library, now = new
     if (!currentlyActiveItems.has(sessionKey)) {
       const lastActivity = lastActivityByItemId.get(session.itemId)
       const endTime = lastActivity || now
-      // Calculate final duration based on last observed ping for that item
-      const sessionDurationSeconds = Math.max(0, Math.floor((endTime.getTime() - session.startTime.getTime()) / 1000))
+
+      // Same reasoning as the update path above: prefer real watched-content
+      // progress (position delta since the session started) over a
+      // checkpoint-timestamp-based duration. Without this, a session whose
+      // provider checkpoint never advanced during the whole time it was
+      // open (state.lastWatched frozen at the same value as the session's
+      // own startTime) would close with endTime === startTime and a stored
+      // durationSeconds of exactly 0, permanently understating (or fully
+      // erasing) real watch time for that session.
+      const lastPosition = lastPositionByItemId.get(session.itemId)
+      const hasPositionData = session.startPosition != null && lastPosition != null
+      const sessionDurationSeconds = hasPositionData
+        ? Math.max(0, Math.floor((lastPosition - session.startPosition) / 1000))
+        : Math.max(0, Math.floor((endTime.getTime() - session.startTime.getTime()) / 1000))
 
       await prisma.watchSession.update({
         where: { id: session.id },

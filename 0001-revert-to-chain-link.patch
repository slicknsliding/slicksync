From 56040b5cecb3fffd64551f21a445c685b1dd9c29 Mon Sep 17 00:00:00 2001
From: Slick <slick@slicksync.local>
Date: Sun, 12 Jul 2026 06:23:37 +0000
Subject: [PATCH] fix: revert to chain-link logo - double-S unreadable at icon
 size

The v1.9.15 double-S mark read fine in a full-size mockup but
collapsed into an unreadable blur at the actual ~28px sidebar icon
size - fine interlocking letterform detail doesn't survive that much
downscaling. Reverted SlickSyncLogo.tsx to the simpler chain-link
geometry (two solid rounded hooks, no fine internal negative space),
which stays legible at icon size. Regenerated logo-white.png,
logo-black.png, favicon.ico, favicon-16x16.png, favicon-32x32.png,
apple-touch-icon.png to match.

Bump to 1.9.16, changelog entry added.
---
 client/components/ui/SlickSyncLogo.tsx |  26 ++++++++++++-------------
 client/public/apple-touch-icon.png     | Bin 5690 -> 4200 bytes
 client/public/changelog.json           |  10 ++++++++++
 client/public/favicon-16x16.png        | Bin 399 -> 304 bytes
 client/public/favicon-32x32.png        | Bin 936 -> 707 bytes
 client/public/favicon.ico              | Bin 1373 -> 1049 bytes
 client/public/logo-black.png           | Bin 17380 -> 12209 bytes
 client/public/logo-white.png           | Bin 17380 -> 12209 bytes
 package.json                           |   2 +-
 9 files changed, 24 insertions(+), 14 deletions(-)

diff --git a/client/components/ui/SlickSyncLogo.tsx b/client/components/ui/SlickSyncLogo.tsx
index a9127e4..c2a38ee 100644
--- a/client/components/ui/SlickSyncLogo.tsx
+++ b/client/components/ui/SlickSyncLogo.tsx
@@ -2,24 +2,24 @@ interface SlickSyncLogoProps {
   className?: string;
 }
 
-// Real Orbitron Black (900) "S" glyph outline, extracted from the font itself
-// so the mark renders identically everywhere regardless of what fonts are
-// installed in the browser (no live-text font dependency).
-const S_PATH =
-  'M202 0Q162 0 128.0 20.0Q94 40 74.0 74.0Q54 108 54 148V215H209V156Q209 156 209.0 156.0Q209 156 209 156H617Q617 156 617.0 156.0Q617 156 617 156V282Q617 282 617.0 282.0Q617 282 617 282H202Q162 282 128.0 302.0Q94 322 74.0 355.5Q54 389 54 430V572Q54 613 74.0 646.5Q94 680 128.0 700.0Q162 720 202 720H626Q666 720 699.5 700.0Q733 680 753.5 646.5Q774 613 774 572V505H617V564Q617 564 617.0 564.0Q617 564 617 564H209Q209 564 209.0 564.0Q209 564 209 564V438Q209 438 209.0 438.0Q209 438 209 438H626Q666 438 699.5 418.0Q733 398 753.5 364.5Q774 331 774 290V148Q774 108 753.5 74.0Q733 40 699.5 20.0Q666 0 626 0Z';
-
 /**
- * SlickSync's mark: two of the same Orbitron "S" glyph, tightly overlapped
- * so the strokes actually cross (not just touching bounding boxes), tilted
- * ~18deg for motion. Flat white fill so it stays legible against every
- * theme's primary/secondary gradient badge background (checked against all
- * 8 themes - all use solid, saturated colors, no low-contrast risk).
+ * SlickSync's chain-link mark, as an inline SVG rather than a static image.
+ * Two simple rounded-rectangle "hooks" overlapping diagonally - deliberately
+ * simple geometry (no fine internal detail) so it stays legible when shrunk
+ * to a ~28px sidebar icon; a bolder letterform mark (tried in v1.9.15)
+ * collapsed to mush at that size even though it read fine in a full-size
+ * mockup. Flat white fill so it stays legible against every theme's
+ * primary/secondary gradient badge background (all 8 themes use solid,
+ * saturated colors - checked against each one) - no separate image assets
+ * or light/dark variants needed.
  */
 export function SlickSyncLogo({ className = 'w-7 h-7' }: SlickSyncLogoProps) {
   return (
     <svg viewBox="0 0 200 200" className={className} xmlns="http://www.w3.org/2000/svg">
-      <path transform="matrix(0.1474,-0.0479,-0.0479,-0.1474,34.2139,137.8986)" d={S_PATH} fill="#ffffff" />
-      <path transform="matrix(0.1474,-0.0479,-0.0479,-0.1474,78.2139,200.8986)" d={S_PATH} fill="#ffffff" />
+      <g fill="none" stroke="#ffffff" strokeWidth={18} strokeLinecap="round">
+        <rect x="30" y="65" width="90" height="50" rx="25" transform="rotate(-35 75 90)" />
+        <rect x="80" y="85" width="90" height="50" rx="25" transform="rotate(-35 125 110)" />
+      </g>
     </svg>
   );
 }

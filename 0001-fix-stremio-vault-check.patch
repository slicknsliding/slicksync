From dbe26b7df3d1d5e717c4929db90b1611581ab27e Mon Sep 17 00:00:00 2001
From: Slick <slick@slicksync.local>
Date: Sun, 12 Jul 2026 07:56:15 +0000
Subject: [PATCH] fix: Stremio Vault check could never report success for any
 credentials

checkStremioAuth required both authResult truthy AND
store.authKey/tempStorage.auth set. Traced via vault-debug.log:
stremio-api-client's store.login() always resolves undefined by
design (its .then() callback has no return statement - success is
signaled via the userChange() side-effect setting store.authKey, not
the resolved value). The authResult && requirement made the success
branch permanently unreachable regardless of whether the login
actually succeeded - confirmed via the debug log showing authResult
undefined on every attempt. This was never a wrong-password or
rate-limit issue; real API errors already threw correctly via the
existing catch block, only the success path was broken.

Now checks store.authKey || tempStorage.auth alone, matching what
userChange() actually sets on success.

Bump to 1.9.24, changelog entry added.
---
 client/public/changelog.json  | 10 ++++++++++
 package.json                  |  2 +-
 server/utils/vaultCheckers.js | 13 ++++++++++++-
 3 files changed, 23 insertions(+), 2 deletions(-)

diff --git a/client/public/changelog.json b/client/public/changelog.json
index 6170eb4..b21bb52 100644
--- a/client/public/changelog.json
+++ b/client/public/changelog.json
@@ -1,4 +1,14 @@
 [
+  {
+    "version": "1.9.24",
+    "date": "2026-07-12",
+    "title": "Fix Stremio Vault check: it could never report success, for any credentials",
+    "bugFixes": [
+      "The Stremio credential check (checkStremioAuth) required both authResult to be truthy AND store.authKey/tempStorage.auth to be set before reporting success. Traced via the new vault-debug.log diagnostics: stremio-api-client's store.login() always resolves to undefined by design, on success and failure alike - its internal .then() callback has no return statement, and success is signaled entirely through the side-effect of setting store.authKey via userChange(), not through the resolved promise value. Requiring authResult to also be truthy made the success branch permanently unreachable, for any credentials, valid or not - this was never actually a wrong-password or rate-limiting issue. Real API errors (genuinely wrong passwords, etc.) already threw correctly and were unaffected. Now checks store.authKey/tempStorage.auth alone."
+    ],
+    "features": [],
+    "miscChores": []
+  },
   {
     "version": "1.9.23",
     "date": "2026-07-11",
diff --git a/package.json b/package.json
index f1fd289..32b9fc7 100644
--- a/package.json
+++ b/package.json
@@ -1,6 +1,6 @@
 {
   "name": "slicksync",
-  "version": "1.9.23",
+  "version": "1.9.24",
   "description": "SlickSync - Stremio addon and user management system",
   "main": "server/index.js",
   "scripts": {
diff --git a/server/utils/vaultCheckers.js b/server/utils/vaultCheckers.js
index 35d4673..6911e7d 100644
--- a/server/utils/vaultCheckers.js
+++ b/server/utils/vaultCheckers.js
@@ -169,7 +169,18 @@ async function checkStremioAuth(secret, config = {}) {
   try {
     const { StremioAPIUtils } = require('./handlers')
     const { store, tempStorage, authResult } = await StremioAPIUtils.authenticateWithStremio(identifier, secret)
-    if (authResult && (store.authKey || tempStorage.auth)) {
+    // stremio-api-client's store.login() always resolves to undefined on
+    // BOTH success and failure by design (its internal .then() callback has
+    // no return statement - success is signaled entirely through the
+    // side-effect of setting store.authKey/tempStorage.auth via
+    // userChange(), not through the resolved value). Requiring authResult
+    // to also be truthy made this check permanently unable to report
+    // success for any credentials, valid or not - confirmed via
+    // /app/data/vault-debug.log showing authResult undefined on every
+    // attempt regardless of outcome. Real API errors (wrong password, etc.)
+    // still throw and are handled by the catch block below - only the
+    // success path was broken.
+    if (store.authKey || tempStorage.auth) {
       return { ok: true, message: 'Stremio login succeeded' }
     }
     // Message-level detail wasn't enough to diagnose the last round of

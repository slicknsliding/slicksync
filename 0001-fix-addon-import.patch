From 4ab510965e90e99af6fb77cc14d6c9f7ae0b817d Mon Sep 17 00:00:00 2001
From: Slick <slick@slicksync.local>
Date: Sun, 12 Jul 2026 01:16:21 +0000
Subject: [PATCH] fix: addon import for non-Stremio accounts (e.g. Nuvio)

GET /:id/stremio-addons was hardcoded to Stremio's API regardless of
providerType, so the Import button always failed with 'User is not
connected to Stremio' for Nuvio accounts - even though Nuvio has its
own getAddons() provider method already used elsewhere (the live
addon count on the Users list).

Route now branches on providerType: non-Stremio accounts go through
the generic provider.getAddons(), with the minimal
{transportUrl, manifest} shape Nuvio returns transformed into the
same {id, name, manifestUrl, version, description, iconUrl, manifest}
shape the frontend already expects from the Stremio path. The
downstream /import-addons POST endpoint was already provider-agnostic
- no changes needed there.

Bump to 1.9.11, changelog entry added.
---
 client/public/changelog.json | 10 ++++++++
 package.json                 |  2 +-
 server/routes/users.js       | 44 +++++++++++++++++++++++++++++++++---
 3 files changed, 52 insertions(+), 4 deletions(-)

diff --git a/client/public/changelog.json b/client/public/changelog.json
index 05f1be6..a5bde6f 100644
--- a/client/public/changelog.json
+++ b/client/public/changelog.json
@@ -1,4 +1,14 @@
 [
+  {
+    "version": "1.9.11",
+    "date": "2026-07-11",
+    "title": "Fix addon import for non-Stremio accounts (e.g. Nuvio)",
+    "bugFixes": [
+      "The Import button's underlying GET /:id/stremio-addons route was hardcoded to Stremio's API regardless of the user's actual providerType, so any Nuvio (or other non-Stremio) account always failed with 'User is not connected to Stremio' - even though Nuvio has its own working getAddons() provider method already used elsewhere (e.g. the live addon count on the Users list). The route now checks providerType and uses the generic provider.getAddons() for non-Stremio accounts, transforming Nuvio's minimal addon shape into the same response shape the frontend already expects."
+    ],
+    "features": [],
+    "miscChores": []
+  },
   {
     "version": "1.9.10",
     "date": "2026-07-11",
diff --git a/package.json b/package.json
index eaa2fa9..e196742 100644
--- a/package.json
+++ b/package.json
@@ -1,6 +1,6 @@
 {
   "name": "slicksync",
-  "version": "1.9.10",
+  "version": "1.9.11",
   "description": "SlickSync - Stremio addon and user management system",
   "main": "server/index.js",
   "scripts": {
diff --git a/server/routes/users.js b/server/routes/users.js
index d2f4049..134f64d 100644
--- a/server/routes/users.js
+++ b/server/routes/users.js
@@ -1721,19 +1721,57 @@ module.exports = ({ prisma, getAccountId, scopedWhere, INSTANCE_TYPE, decrypt, e
   router.get('/:id/stremio-addons', async (req, res) => {
     try {
       const { id } = req.params
-      // Fetch the user's stored Stremio auth
+      // Fetch the full user record - need providerType to know which
+      // provider's addon fetch to use, not just Stremio's
       const user = await prisma.user.findFirst({
         where: {
           id,
           accountId: getAccountId(req)
-        },
-        select: { stremioAuthKey: true }
+        }
       })
 
       if (!user) {
         return responseUtils.notFound(res, 'User')
       }
 
+      // Non-Stremio providers (e.g. Nuvio) don't have a stremioAuthKey at
+      // all - they were previously always rejected here with "not
+      // connected to Stremio" even though the account has its own addon
+      // list. Route those through the provider-agnostic getAddons()
+      // instead, same as the live addon count on the Users list.
+      if (user.providerType && user.providerType !== 'stremio') {
+        try {
+          const provider = createProvider(user, { decrypt, req })
+          if (!provider) {
+            return res.status(400).json({ message: `User is not connected to ${user.providerType}` })
+          }
+          const result = await provider.getAddons()
+          const rawAddons = Array.isArray(result?.addons) ? result.addons : []
+          const addons = rawAddons.map((a) => ({
+            id: a?.manifest?.id || a?.transportUrl || 'unknown',
+            name: a?.manifest?.name || a?.transportName || 'Unknown',
+            manifestUrl: a?.transportUrl || null,
+            version: a?.manifest?.version || 'unknown',
+            description: a?.manifest?.description || '',
+            iconUrl: a?.manifest?.logo || null,
+            manifest: {
+              id: a?.manifest?.id || 'unknown',
+              name: a?.manifest?.name || 'Unknown',
+              version: a?.manifest?.version || 'unknown',
+              description: a?.manifest?.description || '',
+              logo: a?.manifest?.logo || null,
+              types: a?.manifest?.types || ['other'],
+              resources: a?.manifest?.resources || [],
+              catalogs: a?.manifest?.catalogs || []
+            }
+          }))
+          return res.json({ userId: id, count: addons.length, addons })
+        } catch (error) {
+          console.error(`Error fetching ${user.providerType} addons:`, error)
+          return res.status(500).json({ message: `Failed to fetch addons from ${user.providerType}`, error: error.message })
+        }
+      }
+
       if (!user.stremioAuthKey) {
         return res.status(400).json({ message: 'User is not connected to Stremio' })
       }
-- 

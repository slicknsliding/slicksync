generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  username           String
  email              String
  isActive           Boolean   @default(true)
  stremioAuthKey     String? // Encrypted Stremio auth key
  providerType       String    @default("stremio") // "stremio" | "nuvio"
  nuvioRefreshToken  String? // Encrypted Supabase refresh token
  nuvioUserId        String? // Nuvio/Supabase user UUID
  excludedAddons     String? // JSON array of addon IDs that user has excluded
  protectedAddons    String? // JSON array of addon IDs that user has protected
  colorIndex         Int? // UI color theme index
  avatarUrl          String? // Custom profile picture: full URL or /uploads/avatars/<file> for uploaded images
  useGravatar        Boolean   @default(false) // Use Gravatar for avatar instead of generated avatar
  accountId          String? // For multi-tenant support
  expiresAt          DateTime? // When user membership expires (null = never expires)
  inviteCode         String? // Invite code used to create this user (null if created manually)
  discordWebhookUrl  String? // Discord webhook URL for notifications
  discordUserId      String? // Discord user ID for personalized notifications
  apiKey             String? // User-specific API key for accessing own metrics
  activityVisibility String    @default("private") // "public" or "private" - when public, group members can see this user's library/history
  lastSyncedAt       DateTime? // When user addons were last successfully synced
  syncStatus         String? // "idle", "syncing", "success", "error"
  syncErrorMessage   String? // Last sync error message if any
  createdAt          DateTime  @default(now())

  // Relationships

  @@unique([accountId, email, providerType])
  @@unique([accountId, username])
  @@index([expiresAt])
  @@map("users")
}

model Group {
  id                 String  @id @default(cuid())
  name               String
  description        String?
  isActive           Boolean @default(true)
  colorIndex         Int?
  avatarUrl          String?
  accountId          String?
  userIds            String?
  activityVisibility String  @default("private") // DEPRECATED: Use User.activityVisibility instead. Kept for backward compatibility.

  // Relationships
  addons GroupAddon[]

  @@map("groups")
}

// GroupMember and GroupInvite removed – using JSON arrays on Group

model Addon {
  id               String  @id @default(cuid())
  name             String
  description      String?
  manifestUrl      String
  manifest         String? // Encrypted JSON string (AES-GCM)
  originalManifest String? // Encrypted original manifest JSON
  stremioAddonId   String?
  version          String?
  isActive         Boolean @default(true)
  accountId        String?
  iconUrl          String?
  customLogo       String? // Custom logo URL to replace manifest icon
  // Deterministic hash of normalized manifestUrl for search/uniqueness (public mode)
  manifestUrlHash  String? @db.VarChar(64)
  // Normalized HMAC/SHA-256 of processed manifest (content equality check)
  manifestHash     String? @db.VarChar(64)
  // Non-sensitive cached manifest resources for fast UI (JSON string array)
  resources        String?
  // Non-sensitive cached manifest catalogs for fast UI (JSON array of catalog objects with id and type)
  catalogs         String?
  
  // Health check fields
  isOnline         Boolean  @default(true)
  lastHealthCheck  DateTime?
  healthCheckError String?

  // Backup fields
  backupAddonId    String?  // Reference to backup addon (another Addon record)

  // Relationships
  groupAddons GroupAddon[]
  healthHistory AddonHealthHistory[]
  backupAddon      Addon?   @relation("AddonBackup", fields: [backupAddonId], references: [id])
  primaryAddons    Addon[]  @relation("AddonBackup")

  @@unique([name, accountId])
  @@index([manifestUrlHash])
  @@index([manifestHash])
  @@map("addons")
}

model GroupAddon {
  id        String  @id @default(cuid())
  isEnabled Boolean @default(true)
  position  Int?
  groupId   String
  group     Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addonId   String
  addon     Addon   @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([groupId, addonId])
  @@map("group_addons")
}

// Track addon health check history
model AddonHealthHistory {
  id             String   @id @default(cuid())
  addonId        String
  addon          Addon    @relation(fields: [addonId], references: [id], onDelete: Cascade)
  isOnline       Boolean
  error          String?
  checkedAt      DateTime @default(now())
  responseTimeMs Int?

  @@index([addonId, checkedAt])
  @@map("addon_health_history")
}

model AppAccount {
  id           String  @id @default(cuid())
  uuid         String? @unique
  email        String? @unique
  passwordHash String?
  sync         Json?
  apiKeyHash   String? // Encrypted API key

  // Relationships
  invitations Invitation[]

  @@map("app_accounts")
}

model Invitation {
  id                     String    @id @default(cuid())
  accountId              String
  name                   String?
  inviteCode             String    @unique // Short code for URL (e.g., "abc123")
  groupName              String? // Group name to assign users to when they join
  maxUses                Int       @default(0) // 0 = unlimited uses, >0 = limited
  currentUses            Int       @default(0) // Current number of uses
  expiresAt              DateTime? // Optional expiry date for the invitation
  membershipDurationDays Int? // Membership duration in days, applied from user join time
  isActive               Boolean   @default(true)
  syncOnJoin             Boolean   @default(false) // Automatically sync user addons when they join
  createdAt              DateTime  @default(now())

  // Relationships
  account  AppAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  requests InviteRequest[]

  @@index([accountId])
  @@index([inviteCode])
  @@map("invitations")
}

model InviteRequest {
  id             String    @id @default(cuid())
  invitationId   String
  accountId      String
  email          String
  username       String
  status         String    @default("pending") // pending, accepted, rejected
  groupName      String? // Group name to assign user to when accepted
  oauthCode      String? // Stremio OAuth code when accepted
  oauthLink      String? // Stremio OAuth link when accepted
  oauthExpiresAt DateTime? // When OAuth link expires
  stremioAuthKey String? // Encrypted Stremio auth key from upfront OAuth
  createdAt      DateTime  @default(now())
  respondedAt    DateTime?
  respondedBy    String? // accountId who responded

  // Relationships
  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@index([accountId])
  @@index([email])
  @@index([status])
  @@map("invite_requests")
}

// Vault: encrypted credential/account tracking with expiry + active-check monitoring
model VaultEntry {
  id               String    @id @default(cuid())
  accountId        String    @default("default")
  name             String
  category         String
  provider         String?
  secretLabel      String    @default("API Key")
  encryptedSecret  String    @db.Text
  testType         String    @default("manual")
  testConfig       String?   @db.Text
  dashboardUrl     String?
  expiresAt        DateTime?
  notifyDaysBefore Int       @default(3)
  lastCheckedAt    DateTime?
  lastCheckStatus  String?
  lastCheckMessage String?
  lastNotifiedAt   DateTime?
  isActive         Boolean   @default(true)
  position         Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([accountId])
  @@index([accountId, category])
  @@map("vault_entries")
}

// Snapshots: saved addon-set "templates" that can be deployed to any user or group
model AddonSnapshot {
  id          String   @id @default(cuid())
  accountId   String   @default("default")
  name        String
  description String?
  addonsJson  String   @db.Text
  sourceType  String?
  sourceId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
  @@map("addon_snapshots")
}

// Metrics: Watch snapshots - daily snapshots of library items for delta computation
model WatchSnapshot {
  id                 String    @id @default(cuid())
  accountId          String    @default("default")
  userId             String
  itemId             String // Library item ID (e.g., "tt123456" or "tt123456:1:5" for episodes)
  date               DateTime  @db.Date // Date of snapshot (YYYY-MM-DD)
  overallTimeWatched BigInt? // Total watch time in milliseconds
  timeOffset         BigInt? // Current time offset in milliseconds
  lastWatched        DateTime? // Last watched timestamp
  mtime              DateTime? // Library item modification time
  createdAt          DateTime  @default(now())

  @@unique([accountId, userId, itemId, date])
  @@index([accountId, userId, date])
  @@index([accountId, userId, itemId])
  @@map("watch_snapshots")
}

// Metrics: Watch activity - deltas (watch time changes) for accurate daily/weekly stats
model WatchActivity {
  id               String   @id @default(cuid())
  accountId        String   @default("default")
  userId           String
  itemId           String // Library item ID
  date             DateTime @db.Date // Date of watch activity
  watchTimeSeconds Int // Delta: watch time in seconds (only positive changes)
  itemType         String // "movie" or "series"
  createdAt        DateTime @default(now())

  @@index([accountId, userId, date, itemType])
  @@index([accountId, userId, itemId])
  @@index([accountId, date])
  @@map("watch_activity")
}

// Metrics: Episode watch history - tracks individual episode watches for series
// This provides episode-level history since Stremio only keeps the last watched episode per show
model EpisodeWatchHistory {
  id          String   @id @default(cuid())
  accountId   String   @default("default")
  userId      String
  showId      String // Base show ID (e.g., "tt8080122")
  showName    String // Show name for display
  videoId     String // Full video_id (e.g., "tt8080122:4:6" or "kitsu:46676:1")
  season      Int? // Season number (null if unknown)
  episode     Int? // Episode number (null if unknown)
  poster      String? // Show poster URL
  profileLabel String? // Which provider profile this was watched under (e.g. Nuvio profile name), if known
  watchedAt   DateTime // When this episode was watched
  createdAt   DateTime @default(now())

  @@index([accountId, userId, watchedAt])
  @@index([accountId, userId, showId])
  @@unique([accountId, userId, videoId]) // One entry per episode per user
  @@map("episode_watch_history")
}

// Metrics: Movie watch history - the movie equivalent of EpisodeWatchHistory.
// WatchActivity records that a movie was watched (for aggregate counts/streaks)
// but has no title/poster; this table stores that display metadata reliably,
// via the same already-working pipeline that populates EpisodeWatchHistory,
// instead of relying on WatchSession (built for a different, live-detection
// purpose and much less reliably populated for either provider).
model MovieWatchHistory {
  id        String   @id @default(cuid())
  accountId String   @default("default")
  userId    String
  itemId    String // Movie ID (e.g., "tt1234567")
  itemName  String // Movie name for display
  poster    String? // Movie poster URL
  profileLabel String? // Which provider profile this was watched under (e.g. Nuvio profile name), if known
  watchedAt DateTime // When this movie was watched
  createdAt DateTime @default(now())

  @@index([accountId, userId, watchedAt])
  @@unique([accountId, userId, itemId]) // One entry per movie per user
  @@map("movie_watch_history")
}

// Metrics: Watch sessions - tracks individual viewing sessions with start/end times
// Since Stremio only provides cumulative watch time, we track sessions during syncs
model WatchSession {
  id              String    @id @default(cuid())
  accountId       String    @default("default")
  userId          String
  itemId          String // Show/movie ID (e.g., "tt8080122")
  videoId         String? // Episode ID for series (e.g., "tt8080122:4:6")
  itemName        String // Show/movie name for display
  itemType        String // "movie" or "series"
  season          Int? // Season number for series
  episode         Int? // Episode number for series
  poster          String? // Poster URL
  startTime       DateTime // When the viewing session started
  endTime         DateTime? // When it ended (null = still watching)
  startPosition   Int? // Playback position (ms) when this session began - lets
                        // durationSeconds reflect real watched-content progress
                        // (position delta) instead of wall-clock time, since the
                        // provider's position can go stale for a while between
                        // checkpoints. Null for older sessions predating this field.
  durationSeconds Int       @default(0) // Watch duration in seconds
  lastPosition    Int? // Latest known playback position (ms) - a direct
                        // snapshot value, always accurate the instant new
                        // data arrives, unlike a computed session-elapsed
                        // duration which can go stale between checkpoints
  totalDuration   Int? // Content's total runtime (ms), captured alongside
                        // lastPosition
  isActive        Boolean   @default(true) // True if session is still active
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([accountId, userId, startTime])
  @@index([accountId, userId, isActive])
  @@index([accountId, isActive])
  @@map("watch_sessions")
}

// Metrics: Proxy stream sessions - "Now Playing" data sourced from AIOStreams'
// built-in proxy (which sees every stream request passing through it in real
// time, regardless of provider - Stremio, Nuvio, anything using the proxy).
// Deliberately NOT merged into WatchSession: WatchSession was built for a
// different, live-detection purpose and is currently unreliably populated for
// both providers (see MovieWatchHistory comment above). This table is fully
// independent so the AIOStreams integration doesn't inherit that bug, and so
// it keeps working regardless of whether/how the WatchSession issue is fixed.
model ProxyStreamSession {
  id              String    @id @default(cuid())
  accountId       String    @default("default")
  aiostreamsUser  String    // Username as reported by AIOStreams proxy stats (may not map 1:1 to a SlickSync User)
  clientIp        String    // Client IP AIOStreams saw making the request
  requestId       String    // AIOStreams' per-connection request ID - stable identity for one stream, used to match start/end
  url             String    // Full upstream URL being proxied (may contain the raw source link)
  filename        String?   // Raw filename AIOStreams reported, e.g. "Powder.1995.1080p.AMZN.WEB-DL.DD5.1.H.264-SiGMA"
  displayName     String?   // Best-effort cleaned-up title parsed from filename, e.g. "Powder (1995)"
  startTime       DateTime  // When AIOStreams first reported this connection active
  endTime         DateTime? // When AIOStreams stopped reporting it as active (null = still active)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([accountId, requestId])
  @@index([accountId, isActive])
  @@index([accountId, aiostreamsUser, isActive])
  @@map("proxy_stream_sessions")
}

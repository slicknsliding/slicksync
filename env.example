REDIS_URL=
JWT_SECRET=
ENCRYPTION_KEY=
DEBUG=false
NEXT_PUBLIC_DEBUG=false

# User/Group IDs for Docker (optional - defaults to 1000:1000)
# Run 'id' command to get your UID and GID
UID=1000
GID=1000
# --- Nuvio provider (optional overrides; defaults target Nuvio's public Supabase) ---
# NUVIO_SUPABASE_URL=
# NUVIO_SUPABASE_ANON_KEY=

# --- Rate limiting for credential endpoints ---
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX_REQUESTS=20
# POLL_RATE_LIMIT_MAX_REQUESTS=60

# --- Day bucketing ---
# Background pollers have no request context to infer a timezone from, so the
# day boundary for Watch Time Today / streaks is an explicit setting.
# Overridden per-account in Settings -> Privacy & Display.
# ACCOUNT_TIMEZONE=America/Los_Angeles

# --- Vault ---
# How often the decrypted Vault snapshot is written to data/backup/vault/
# VAULT_BACKUP_INTERVAL_HOURS=24

# --- AIOStreams proxy (optional; powers live Now Playing presence) ---
# Leave unset to fall back to provider-native polling for Now Playing.
# AIOSTREAMS_URL=https://aiostreams.example.com
# AIOSTREAMS_AUTH_USERNAME=
# AIOSTREAMS_AUTH_PASSWORD=
# Comma-separated SlickSync user IDs to attribute proxy-detected activity to
# when username/email matching can't resolve one.
# AIOSTREAMS_FALLBACK_USER_IDS=
